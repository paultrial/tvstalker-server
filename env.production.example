# Image / compose
TVSTALKER_TAG=latest
API_PORT=3000

# App
PORT=3000
NODE_ENV=production
MONGO_URI=mongodb://tvstalker:change_me@mongo:27017/Series?authSource=admin
SESSION_SECRET=change_me_with_a_long_random_secret
SESSION_COOKIE_NAME=session
CORS_ORIGIN=https://tvstalker.your-domain.com
COOKIE_SAMESITE=none
COOKIE_SECURE=true

# Jobs
DISABLE_JOBS=false
RARBG_CRON=0 */6 * * *
FILELIST_CRON=15 */6 * * *
TVMAZE_CRON=0 3 * * 1
TVMAZE_RUN_ON_START=false
FILELIST_PASSKEY=
FILELIST_FEED_URL=

# OpenSubtitles (optional)
OPENSUBTITLES_USER=
OPENSUBTITLES_PASS=
OPENSUBTITLES_LANG=rum
OPENSUBTITLES_USERAGENT=OpenSubtitlesPlayer v4.7

# Mail (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@seriale.local

# Mongo root user (used by mongo container)
MONGO_INITDB_ROOT_USERNAME=tvstalker
MONGO_INITDB_ROOT_PASSWORD=change_me
